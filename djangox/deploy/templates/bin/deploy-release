#!/bin/bash
set -euo pipefail

PROJECT_NAME="{{ project_name }}"
PROJECT_REPO="{{ project_repo }}"
DJANGOX_REPO="{{ djangox_repo }}"
BRANCH="{{ branch }}"
HOME_DIR="{{ home }}"
CURRENT_PATH="{{ current_path }}"
STATIC_PATH="{{ static_path }}"
SETTINGS_PACKAGE="{{ settings_package }}"
STATIC_DIR="{{ static_dir }}"
SERVER_NAME="{{ server_name }}"
GUNICORN_PORT="{{ gunicorn_port }}"
HEALTH_PATH="{{ health_path }}"
KEEP_RELEASES="{{ keep_releases }}"
GIT_SSH_COMMAND="{{ git_ssh_command }}"

export GIT_SSH_COMMAND
export DJANGO_SETTINGS_MODULE="$SETTINGS_PACKAGE.production"
export PYTHONUNBUFFERED=TRUE
export AWS_DEFAULT_REGION="{{ aws_region }}"

: "${SECRET_SETTINGS_SOURCE:?}"
: "${PRODUCTION_SETTINGS_SOURCE:?}"

old_release="$(readlink "$CURRENT_PATH" 2>/dev/null || true)"
old_static="$(readlink "$STATIC_PATH" 2>/dev/null || true)"
work_dir=""

rollback() {
    if [ -n "$old_release" ]; then
        ln -sfn "$old_release" "$CURRENT_PATH.next"
        mv -Tf "$CURRENT_PATH.next" "$CURRENT_PATH"
    fi
    if [ -n "$old_static" ]; then
        ln -sfn "$old_static" "$STATIC_PATH.next"
        mv -Tf "$STATIC_PATH.next" "$STATIC_PATH"
    fi
    reload_gunicorn
}

reload_gunicorn() {
    if sudo systemctl is-active --quiet gunicorn.service; then
        current_venv="$(readlink -f "$CURRENT_PATH/.venv")"
        if pgrep -af -- "--chdir $CURRENT_PATH" | grep -F "$current_venv/" >/dev/null; then
            sudo systemctl reload gunicorn.service
            return
        fi
        sudo systemctl restart gunicorn.service
        return
    fi

    sudo systemctl start gunicorn.service
}

check_health() {
    for _ in $(seq 1 30); do
        if curl --fail --silent --show-error --max-time 10 -H "Host: $SERVER_NAME" "http://127.0.0.1:$GUNICORN_PORT$HEALTH_PATH" >/dev/null; then
            return 0
        fi
        sleep 1
    done

    return 1
}

cleanup_work_dir() {
    if [ -n "${work_dir:-}" ] && [ -d "$work_dir" ]; then
        rm -rf "$work_dir"
    fi
}

cleanup_old_dirs() {
    prefix="$1"
    active="$2"
    ls -dt "$HOME_DIR/$prefix"-[0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9][0-9][0-9] 2>/dev/null | tail -n +"$((KEEP_RELEASES + 1))" | while read -r old_dir; do
        if [ "$(readlink -f "$old_dir")" != "$active" ]; then
            rm -rf "$old_dir"
        fi
    done
}

trap cleanup_work_dir EXIT

if [ -d "$HOME_DIR/djangox/.git" ]; then
    git -C "$HOME_DIR/djangox" fetch origin
    git -C "$HOME_DIR/djangox" reset --hard origin/HEAD
else
    git clone "$DJANGOX_REPO" "$HOME_DIR/djangox"
fi

if [ -n "$old_release" ] && [ -d "$old_release/.git" ]; then
    git -C "$old_release" fetch origin "$BRANCH"
    if [ "$(git -C "$old_release" rev-parse HEAD)" = "$(git -C "$old_release" rev-parse FETCH_HEAD)" ]; then
        reload_gunicorn
        check_health
        printf "already active: %s\n" "$old_release"
        exit 0
    fi
fi

old_release_real="$(readlink -f "$old_release" 2>/dev/null || true)"
reusable_release="$(
    for dir in "$HOME_DIR/$PROJECT_NAME"-[0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9][0-9][0-9]; do
        [ -d "$dir" ] || continue
        [ "$(readlink -f "$dir")" = "$old_release_real" ] && continue
        printf '%s\n' "$dir"
    done | sort | head -n 1
)"

if [ -n "$reusable_release" ]; then
    work_dir="$(mktemp -d "$HOME_DIR/$PROJECT_NAME-build-XXXXXX")"
    rmdir "$work_dir"
    mv "$reusable_release" "$work_dir"
    git -C "$work_dir" remote set-url origin "$PROJECT_REPO"
    git -C "$work_dir" checkout "$BRANCH"
    git -C "$work_dir" clean -fd -e .venv -e "$STATIC_DIR/node_modules"
    git -C "$work_dir" pull --ff-only origin "$BRANCH"
else
    work_dir="$(mktemp -d "$HOME_DIR/$PROJECT_NAME-build-XXXXXX")"
    git clone --branch "$BRANCH" "$PROJECT_REPO" "$work_dir"
fi

commit="$(git -C "$work_dir" rev-parse HEAD)"
stamp="$(git -C "$work_dir" show -s --format=%cd --date=format:%y%m%d-%H%M%S "$commit")"
release_dir="$HOME_DIR/$PROJECT_NAME-$stamp"
static_release_dir="$HOME_DIR/static-$stamp"

if [ "$old_release" = "$release_dir" ]; then
    reload_gunicorn
    check_health
    printf "already active: %s\n" "$release_dir"
    exit 0
fi

if [ -d "$release_dir" ]; then
    rm -rf "$release_dir"
fi
mv "$work_dir" "$release_dir"
work_dir=""

rm -rf "$static_release_dir"
mkdir -p "$static_release_dir"

python3 -m venv "$release_dir/.venv"
cd "$release_dir"
runtime_requirements="$(mktemp)"
grep -Ev '^(pyinfra|aws-cdk-lib|constructs)([<>= ].*)?$' requirements.txt > "$runtime_requirements"
"$release_dir/.venv/bin/python" -m pip install -r "$runtime_requirements"
rm -f "$runtime_requirements"

cp "$SECRET_SETTINGS_SOURCE" "$release_dir/$SETTINGS_PACKAGE/secret_settings.py"
cp "$PRODUCTION_SETTINGS_SOURCE" "$release_dir/$SETTINGS_PACKAGE/production.py"

cd "$release_dir/$STATIC_DIR"
npm install
npm run build-css

cd "$release_dir"
DJANGO_STATIC_ROOT="$static_release_dir" "$release_dir/.venv/bin/python" manage.py collectstatic --noinput --settings="$SETTINGS_PACKAGE.production"
"$release_dir/.venv/bin/python" manage.py migrate --noinput --settings="$SETTINGS_PACKAGE.production"
"$release_dir/.venv/bin/python" manage.py check --settings="$SETTINGS_PACKAGE.production"

ln -sfn "$release_dir" "$CURRENT_PATH.next"
mv -Tf "$CURRENT_PATH.next" "$CURRENT_PATH"
ln -sfn "$static_release_dir" "$STATIC_PATH.next"
mv -Tf "$STATIC_PATH.next" "$STATIC_PATH"

if ! reload_gunicorn; then
    rollback
    exit 1
fi

if ! check_health; then
    rollback
    exit 1
fi

sudo nginx -t
sudo systemctl reload nginx
sudo systemctl enable gunicorn.service >/dev/null

current_real="$(readlink -f "$CURRENT_PATH")"
static_real="$(readlink -f "$STATIC_PATH")"

cleanup_old_dirs "$PROJECT_NAME" "$current_real"
cleanup_old_dirs static "$static_real"

printf "active: %s\n" "$release_dir"
